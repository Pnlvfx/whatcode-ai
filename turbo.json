{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "tsc": {
      "dependsOn": ["^tsc"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true
    },
    "initialize": {
      "dependsOn": ["^initialize"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"],
      "cache": true
    }
  }
}
