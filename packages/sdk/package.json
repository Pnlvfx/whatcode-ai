{
  "name": "@whatcode-ai/sdk",
  "version": "1.16.0",
  "description": "Core SDK to start opencode and optionally expose it over HTTPS via Tailscale — connect from anywhere.",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server",
    "https",
    "tunnel",
    "remote",
    "whatcode"
  ],
  "homepage": "https://www.whatcode.app/",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/whatcode.ts",
    "./logger": "./src/logger.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "lint": "eslint",
    "prepack": "yarn build",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.15.12",
    "execa": "^9.6.1",
    "exit-hook": "^5.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.0.0",
    "node-machine-id": "^1.1.12",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.23.0",
    "@goatjs/rimraf": "^2.10.0",
    "@goatjs/typescript-config": "^2.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/whatcode.d.ts",
        "import": "./dist/whatcode.js"
      },
      "./logger": {
        "types": "./dist/logger.d.ts",
        "import": "./dist/logger.js"
      }
    }
  }
}
