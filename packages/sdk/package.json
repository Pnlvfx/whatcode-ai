{
  "name": "@whatcode-ai/sdk",
  "version": "1.17.0",
  "description": "Core SDK to start opencode and optionally expose it over HTTPS via Tailscale — connect from anywhere.",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server",
    "https",
    "tunnel",
    "remote",
    "whatcode"
  ],
  "homepage": "https://www.whatcode.app/",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/sdk"
  },
  "license": "MIT",
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/whatcode.ts",
    "./logger": "./src/logger.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "lint": "eslint",
    "prepack": "yarn build",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.4",
    "execa": "^9.6.1",
    "exit-hook": "^5.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.1.0",
    "node-machine-id": "^1.1.12",
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@goatjs/node-monorepo-eslint": "^2.31.0",
    "@goatjs/rimraf": "^2.11.0",
    "@goatjs/typescript-config": "^2.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/semver": "^7.7.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/whatcode.d.ts",
        "import": "./dist/whatcode.js"
      },
      "./logger": {
        "types": "./dist/logger.d.ts",
        "import": "./dist/logger.js"
      }
    }
  }
}
