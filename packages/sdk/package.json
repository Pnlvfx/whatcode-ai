{
  "name": "@whatcode-ai/sdk",
  "description": "SDK and CLI to start opencode and optionally expose it over HTTPS via Tailscale.",
  "version": "1.7.0",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server"
  ],
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Pnlvfx/whatcode-ai#readme",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "unused": "node tools/unused.ts",
    "test": "",
    "lint": "eslint",
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "^1.3.13",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.1.0",
    "@goatjs/rimraf": "^1.80.0",
    "@goatjs/typescript-config": "^1.80.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
