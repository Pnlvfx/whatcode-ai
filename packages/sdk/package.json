{
  "name": "@whatcode-ai/sdk",
  "description": "SDK and CLI to start opencode and optionally expose it over HTTPS via Tailscale.",
  "version": "1.0.1",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server"
  ],
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Pnlvfx/whatcode-ai#readme",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "unused": "node tools/unused.ts",
    "test": "",
    "lint": "eslint",
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@opencode-ai/sdk": "^1.2.26",
    "execa": "^9.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^1.47.0",
    "@goatjs/rimraf": "^1.72.0",
    "@goatjs/typescript-config": "^1.72.0",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3"
  },
  "bin": {
    "whatcode": "dist/cli.js"
  }
}
