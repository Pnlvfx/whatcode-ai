{
  "name": "@whatcode-ai/whatcode",
  "version": "1.19.0",
  "description": "CLI to start opencode and optionally expose it over HTTPS via Tailscale — connect to your AI coding assistant from anywhere.",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "server",
    "https",
    "tunnel",
    "remote",
    "whatcode"
  ],
  "homepage": "https://www.whatcode.app/",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/whatcode"
  },
  "license": "MIT",
  "author": {
    "name": "Simone Gauli",
    "email": "simonegauli@gmail.com"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": "./src/cli.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "lint": "eslint",
    "prepack": "yarn build",
    "prepare": "yarn build",
    "prepublishOnly": "yarn test && eslint",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@whatcode-ai/sdk": "workspace:*",
    "qrcode-terminal": "^0.12.0",
    "update-notifier": "^7.3.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/config-helpers": "^0.6.0",
    "@goatjs/node-monorepo-eslint": "^2.39.0",
    "@goatjs/rimraf": "^2.11.0",
    "@goatjs/typescript-config": "^2.2.0",
    "@types/node": "^26.0.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/update-notifier": "^6.0.8",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "whatcode": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./logger": {
        "types": "./dist/logger.d.ts",
        "import": "./dist/logger.js"
      }
    }
  }
}
