{
  "name": "@whatcode-ai/whatcode",
  "description": "SDK and CLI to start opencode and optionally expose it over HTTPS via Tailscale.",
  "version": "1.7.0",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server"
  ],
  "author": {
    "email": "simonegauli@gmail.com",
    "name": "Simone Gauli"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git",
    "directory": "packages/whatcode"
  },
  "homepage": "https://github.com/Pnlvfx/whatcode-ai#readme",
  "bugs": {
    "url": "https://github.com/Pnlvfx/whatcode-ai/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": "./src/cli.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "whatcode": "./dist/cli.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "unused": "node tools/unused.ts",
    "test": "",
    "lint": "eslint",
    "build": "rimraf dist && eslint && tsc -p tsconfig.build.json",
    "prepare": "yarn build",
    "prepack": "yarn build",
    "prepublishOnly": "yarn test && eslint"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@whatcode-ai/sdk": "workspace:*",
    "update-notifier": "^7.3.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@goatjs/node-monorepo-eslint": "^2.13.0",
    "@goatjs/rimraf": "^1.86.0",
    "@goatjs/typescript-config": "^1.86.0",
    "@types/node": "^25.6.0",
    "@types/update-notifier": "^6.0.8",
    "@types/yargs": "^17.0.35",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
