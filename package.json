{
  "name": "whatcode-ai",
  "private": true,
  "description": "Monorepo for WhatCode. One-script setup to start opencode and expose it over HTTPS via Tailscale from anywhere.",
  "keywords": [
    "opencode",
    "tailscale",
    "ai",
    "cli",
    "sdk",
    "server",
    "https",
    "tunnel",
    "remote"
  ],
  "homepage": "https://www.whatcode.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pnlvfx/whatcode-ai.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "yarn whatcode --log-level debug --port 6666 --opencode-port 4099",
    "docs": "yarn workspace @whatcode-ai/docs",
    "lint": "turbo run lint",
    "prepare": "lefthook install",
    "tsc": "turbo run tsc",
    "update": "yarn upgrade-interactive"
  },
  "resolutions": {
    "@goatjs/store": "file:packages/sdk/vendor/goatjs-store.tgz",
    "@coraline/core": "file:packages/sdk/vendor/coraline-core.tgz",
    "@coraline/client": "file:packages/sdk/vendor/coraline-client.tgz",
    "@goatjs/core": "file:packages/sdk/vendor/goatjs-core.tgz",
    "@coraline/server": "file:packages/sdk/vendor/coraline-server.tgz",
    "@goatjs/node": "file:packages/sdk/vendor/goatjs-node.tgz"
  },
  "dependencies": {
    "@whatcode-ai/whatcode": "workspace:*"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/config-helpers": "^0.6.0",
    "@goatjs/dbz": "^2.48.0",
    "@goatjs/doctor": "^2.42.0",
    "@goatjs/node-monorepo-eslint": "^2.31.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
